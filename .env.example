# contest-pipeline environment — copy to .env and fill in your values
# (this file is safe to commit; .env is gitignored)

# Your contact email (used in some submission forms)
PHOTOGRAPHER_EMAIL=your@email.com

# Name as it should appear on submissions
PHOTOGRAPHER_NAME=Your Name

# Path to your source photo library (override PHOTOS_DIR in contest_pipeline.py)
# PHOTOS_DIR=/path/to/your/photos
